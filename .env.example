# --- Riot API ---
# Pobierz z https://developer.riotgames.com (Development API Key).
# UWAGA: development key wygasa co 24h, trzeba go odświeżać.
# Skopiuj ten plik do `.env` i wklej klucz. .env jest w .gitignore i NIGDY nie trafia do repo.
# Na Vercel ustaw tę zmienną w Project Settings → Environment Variables.
RIOT_API_KEY=

# --- Baza danych (libSQL / Turso) ---
# LOKALNIE: zostaw te dwie zmienne PUSTE — użyty zostanie plik `file:./data/tracker.db`.
# PRODUKCJA (Vercel): utwórz darmową bazę na https://turso.tech i wklej:
#   TURSO_DATABASE_URL=libsql://<twoja-baza>.turso.io
#   TURSO_AUTH_TOKEN=<token z `turso db tokens create`>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
